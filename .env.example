# Optional. If set, Harbor uses Claude to generate richer action plans and
# parse outreach notes. If unset, the app falls back to a deterministic template
# so the demo always works.
ANTHROPIC_API_KEY=

# Optional model override. Defaults to a current Claude model.
ANTHROPIC_MODEL=claude-sonnet-4-6

# Required for outreach/admin accounts. Create a Supabase project, then copy
# these from Project Settings -> API or the project Connect dialog.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Optional. If set, results cards can embed Google Maps directions directly
# using the official Maps Embed API. Without this key, Harbor falls back to a
# standard Google Maps iframe preview and route links.
NEXT_PUBLIC_GOOGLE_MAPS_EMBED_API_KEY=
